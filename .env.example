# =========================================================================
# Digital Product Studio — variables de entorno (ejemplo)
# Copia este archivo a .env y rellena los valores reales.
# NUNCA commitees .env (está en .gitignore).
# =========================================================================

# Base de datos PostgreSQL (en TODOS los entornos). Formato:
#   postgresql://USUARIO:CONTRASEÑA@HOST:5432/NOMBRE_DB?schema=public
# En local puedes levantar uno con:  docker compose up -d db
DATABASE_URL="postgresql://dps_user:dps_password@localhost:5432/digital_product_studio?schema=public"

# Modelo de chat de OpenAI por defecto (cambiable sin tocar código y desde /settings).
# Debe soportar structured outputs (json_schema). Ej: gpt-4o-mini, gpt-4o, gpt-4.1-mini.
OPENAI_MODEL=gpt-4o-mini

# BYOK: la app NO usa ninguna OPENAI_API_KEY de servidor. Cada usuario aporta su
# propia API key desde /settings (se guarda solo en su navegador). No la pongas aquí.

# Radar de Anuncios: URL del microservicio (robot Puppeteer en contenedor aparte).
# En local apunta al contenedor que ya tienes corriendo. En producción, a la URL
# interna del servicio desplegado (ej. http://jp-radar:3000 en la misma red Docker).
RADAR_URL=http://localhost:3010

# Opcional: secreto compartido si añades autenticación al robot (cabecera x-radar-key).
# RADAR_SECRET=
