# =========================================================================
# Digital Product Studio — variables de entorno (ejemplo)
# Copia este archivo a .env.local y rellena los valores reales.
# NUNCA commitees .env.local ni expongas estos secretos en el cliente.
# =========================================================================

# Base de datos (SQLite en desarrollo). Prisma la lee desde aquí.
DATABASE_URL="file:./dev.db"

# API key del modelo de IA (SOLO lado servidor — nunca NEXT_PUBLIC_*).
OPENAI_API_KEY=

# Modelo de chat de OpenAI a usar (cambiable sin tocar código).
# Debe soportar structured outputs (json_schema). Ej: gpt-4o-mini, gpt-4o, gpt-4.1-mini.
OPENAI_MODEL=gpt-4o-mini
